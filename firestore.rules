rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: rsvps
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - status: string (required: 'yes' | 'no')
    //   - childrenNames: list (required, max 3 children)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function hasOnlyAllowedFields() {
      return request.resource.data.keys().hasAll(['name', 'createdAt', 'status', 'childrenNames']) &&
          request.resource.data.keys().hasOnly(['name', 'createdAt', 'status', 'childrenNames']);
    }
    
    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidStatus() {
      return request.resource.data.status in ['yes', 'no'];
    }

    function isValidChildrenNames() {
      return request.resource.data.childrenNames is list &&
        request.resource.data.childrenNames.size() <= 3 &&
        (request.resource.data.childrenNames.size() == 0 ||
          isValidChild(request.resource.data.childrenNames[0])) &&
        (request.resource.data.childrenNames.size() <= 1 ||
          isValidChild(request.resource.data.childrenNames[1])) &&
        (request.resource.data.childrenNames.size() <= 2 ||
          isValidChild(request.resource.data.childrenNames[2]));
    }

    function isValidChild(child) {
      return child is map &&
        child.keys().hasAll(['name', 'isUnder12']) &&
        child.keys().hasOnly(['name', 'isUnder12']) &&
        child.name is string &&
        child.name.size() > 0 &&
        child.name.size() <= 80 &&
        child.isUnder12 is bool;
    }

    function isValidStatusChildrenRelation() {
      return request.resource.data.status == 'yes' ||
        request.resource.data.childrenNames.size() == 0;
    }

    function isValidRSVP() {
      return hasOnlyAllowedFields() &&
             isValidStringLength('name', 2, 100) &&
             isValidStatus() &&
             isValidChildrenNames() &&
             isValidStatusChildrenRelation() &&
             request.resource.data.createdAt is timestamp;
    }

    match /rsvps/{rsvpId} {
      // Allow anyone to read the RSVPs to get the total count
      allow read: if true;
      
      // Allow anyone to create an RSVP if the data is valid
      allow create: if isValidRSVP();
      
      // Allow delete for the admin panel
      allow delete: if true;
      
      // Do not allow updates
      allow update: if false;
    }
  }
}
